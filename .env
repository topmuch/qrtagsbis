# QRTags Environment Configuration

# Database (SQLite - local file)
DATABASE_URL=file:./qrtags.db

# Base URL for your application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth Secret
NEXTAUTH_SECRET=qrtags-dev-secret-key-2024-supersecure32ch
NEXTAUTH_URL=http://localhost:3000

# PayPal Configuration (sandbox placeholders)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=sandbox-placeholder
PAYPAL_CLIENT_SECRET=sandbox-placeholder

# Encryption Key
ENCRYPTION_KEY=qrtags-encryption-key-2024-secure32

# ─── WAKIT (WhatsApp Business API) ───
WAKIT_API_KEY=
WAKIT_BASE_URL=https://api.wakit.ai/v1
WAKIT_PHONE_NUMBER_ID=
WAKIT_TEMPLATE_SCAN_ALERT=tag_scan_alert
WAKIT_TIMEOUT_MS=10000

# ─── GROQ (AI Inference) ───
GROQ_API_KEY=
GROQ_MODEL_CHAT=llama3-8b-8192
GROQ_MODEL_ANALYSIS=llama3-8b-8192
GROQ_TIMEOUT_MS=30000

# ─── GROQ AI — Master kill switch ───
GROQ_AI_ENABLED=false

# ─── AI Feature Kill Switches ───
GROQ_CHAT_ENABLED=false
GROQ_SCAN_GUARD_ENABLED=false
GROQ_AUTO_TRANSLATE_ENABLED=false
